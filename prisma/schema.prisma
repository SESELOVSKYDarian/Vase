generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  USER
}

enum TenantRole {
  OWNER
  MANAGER
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
}

enum BusinessPlan {
  START
  PREMIUM
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CollectionStatus {
  ACTIVE
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum PriceListType {
  RETAIL
  WHOLESALE
  SPECIAL
}

enum OfferStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ShippingZoneType {
  FLAT
  DISTANCE
}

enum DistancePricingMode {
  FIXED
  PER_KM
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELED
}

enum CheckoutMethod {
  EMAIL
  WHATSAPP
  TRANSFER
  ONLINE
  CASH_ON_PICKUP
  MANUAL
}

enum OrderChannel {
  WEB
  EMAIL
  WHATSAPP
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum ErpConnectionStatus {
  ACTIVE
  PAUSED
  FAILED
}

enum SyncJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum OnboardingProduct {
  BUSINESS
  LABS
  BOTH
}

enum ModuleProduct {
  BUSINESS
  LABS
}

enum ModulePricingType {
  ONE_TIME
  MONTHLY
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum StorefrontPageStatus {
  DRAFT
  ACTIVE
  TEMPORARY
  EXPIRED
  PENDING_REMOVAL
  ARCHIVED
}

enum StorefrontTemplateKey {
  STARTER
  SHOWCASE
  CATALOG
}

enum StorefrontPageVersionKind {
  AUTOSAVE
  MANUAL
  PUBLISHED
}

enum DomainConnectionStatus {
  NOT_CONFIGURED
  PENDING_PAYMENT
  PENDING_VERIFICATION
  CONNECTED
  FAILED
}

enum CustomPageRequestStatus {
  SUBMITTED
  REVIEWING
  QUOTED
  IN_PROGRESS
  DELIVERED
}

enum CustomPageRequestType {
  TEMPLATE_CUSTOMIZATION
  FULL_CUSTOMIZATION
}

enum CustomQuoteStatus {
  DRAFT
  PENDING_CLIENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CustomQuoteLineType {
  BASE_TEMPLATE
  FEATURE
  DESIGN
  INTEGRATION
  SERVICE
}

enum CustomQuoteRevisionType {
  CREATED
  UPDATED
  SENT_TO_CLIENT
  ACCEPTED_BY_CLIENT
  REJECTED_BY_CLIENT
  MARKED_EXPIRED
}

enum IntegrationCredentialStatus {
  ACTIVE
  ROTATED
  REVOKED
}

enum IntegrationWebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

enum AiWorkspacePlan {
  START
  PREMIUM
}

enum AiTrainingJobStatus {
  DRAFT
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum AiKnowledgeItemType {
  FILE
  FAQ
  URL
}

enum AiKnowledgeItemStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum AiAssistantTone {
  WARM
  PROFESSIONAL
  CONCISE
  PREMIUM
  FRIENDLY
}

enum AiChannelType {
  WHATSAPP
  INSTAGRAM
  WEBCHAT
}

enum AiChannelStatus {
  DISCONNECTED
  PENDING
  CONNECTED
  ERROR
}

enum AiConversationStatus {
  OPEN
  ESCALATED
  CLOSED
}

enum AiEscalationDestination {
  EMAIL
  WHATSAPP
  HUMAN_QUEUE
  CRM
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  QUEUED
  ASSIGNED
  WAITING_CUSTOMER
  WAITING_INTERNAL
  RESOLVED
  RETURNED_TO_AI
  CLOSED
}

enum SupportTicketSource {
  AI_ESCALATION
  MANUAL
}

enum SupportAssignmentMode {
  MANUAL
  AUTOMATIC
}

enum SupportTicketEventType {
  CREATED
  ESCALATED_FROM_AI
  ASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  NOTE_ADDED
  AGENT_REPLIED
  CUSTOMER_UPDATED
  RETURNED_TO_AI
  RESOLVED
  CLOSED
}

enum SupportNotificationType {
  NEW_TICKET
  TICKET_ASSIGNED
  WAITING_TOO_LONG
  CUSTOMER_REPLY
  STATUS_UPDATED
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  platformRole  PlatformRole @default(USER)
  locale        String       @default("es")
  passwordChangedAt DateTime?
  lastLoginAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  auditLogs     AuditLog[]   @relation("AuditActor")
  authTokens    AuthToken[]
  createdSupportTickets SupportTicket[] @relation("SupportTicketCreatedBy")
  assignedSupportTickets SupportTicket[] @relation("SupportTicketAssignedTo")
  supportNotes  SupportTicketNote[] @relation("SupportNoteAuthor")
  supportTemplates SupportReplyTemplate[] @relation("SupportTemplateAuthor")
  supportNotifications SupportNotification[] @relation("SupportNotificationRecipient")
  supportTicketEvents SupportTicketEvent[] @relation("SupportTicketActor")
  supportKnowledgeItems SupportKnowledgeItem[] @relation("SupportKnowledgeCreatedBy")
  supportAiResponseLogs SupportAiResponseLog[] @relation("SupportAiResponseRequestedBy")
  createdCustomQuotes CustomQuote[] @relation("CustomQuoteCreatedBy")
  updatedCustomQuotes CustomQuote[] @relation("CustomQuoteUpdatedBy")
  customQuoteRevisions CustomQuoteRevision[] @relation("CustomQuoteRevisionActor")
  productReviews ProductReview[]
  priceListAssignments UserPriceList[]
  placedOrders   Order[]         @relation("OrderPlacedBy")
  platformUpdateReads PlatformUpdateRead[]
  shortcuts     Json?
}

model Tenant {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  accountName       String
  billingEmail      String?
  industry          String
  onboardingProduct OnboardingProduct @default(BUSINESS)
  status            TenantStatus      @default(TRIAL)
  locale            String            @default("es")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  memberships       Membership[]
  projects          Project[]
  featureFlags      FeatureFlag[]
  tenantModules     TenantModule[]
  auditLogs         AuditLog[]
  subscription      TenantSubscription?
  storefrontPages   StorefrontPage[]
  customPageRequests CustomPageRequest[]
  domainConnections DomainConnection[]
  integrationApiCredentials IntegrationApiCredential[]
  integrationUsageLogs IntegrationUsageLog[]
  integrationWebhooks IntegrationWebhookEndpoint[]
  aiWorkspace       TenantAiWorkspace?
  aiKnowledgeItems  AiKnowledgeItem[]
  aiTrainingJobs    AiTrainingJob[]
  aiChannels        AiChannelConnection[]
  aiConversations   AiConversation[]
  supportTickets    SupportTicket[]
  supportTemplates  SupportReplyTemplate[]
  supportNotifications SupportNotification[]
  supportKnowledgeItems SupportKnowledgeItem[]
  supportAiResponseLogs SupportAiResponseLog[]
  customQuotes      CustomQuote[]
  categories        Category[]
  products          Product[]
  productReviews    ProductReview[]
  productCollections ProductCollection[]
  priceLists        PriceList[]
  userPriceLists    UserPriceList[]
  productPriceOverrides ProductPriceOverride[]
  tenantOffers      TenantOffer[]
  shippingBranches  ShippingBranch[]
  shippingZones     ShippingZone[]
  orders            Order[]
  payments          Payment[]
  erpConnections    ErpConnection[]
  syncJobs          SyncJob[]
  productSyncRecords ProductSyncRecord[]
}

model Membership {
  id         String           @id @default(cuid())
  userId     String
  tenantId   String
  role       TenantRole
  status     MembershipStatus @default(ACTIVE)
  lastSeenAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId, role])
}

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String?
  key         String
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model Module {
  id           String          @id
  name         String          @unique
  description  String?
  product      ModuleProduct
  route        String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  pricing      ModulePricing[]
  tenantLinks  TenantModule[]
}

model ModulePricing {
  id         String            @id @default(cuid())
  moduleId   String
  price      Decimal           @db.Decimal(10, 2)
  currency   String            @default("USD")
  type       ModulePricingType
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  module     Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, isActive, createdAt])
}

model TenantModule {
  id         String    @id @default(cuid())
  tenantId    String
  moduleId    String
  isActive    Boolean   @default(true)
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, isActive])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  scope       String
  windowStart DateTime
  count       Int      @default(0)

  @@unique([key, scope, windowStart])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AuthToken {
  id         String        @id @default(cuid())
  userId     String
  type       AuthTokenType
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, tokenHash])
  @@index([userId, type, expiresAt])
}

model TenantSubscription {
  id                   String        @id @default(cuid())
  tenantId             String        @unique
  plan                 BusinessPlan  @default(START)
  billingStatus        BillingStatus @default(TRIAL)
  premiumEnabled       Boolean       @default(false)
  customDomainEnabled  Boolean       @default(false)
  temporaryPagesEnabled Boolean      @default(true)
  currentPeriodEndsAt  DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model StorefrontPage {
  id               String               @id @default(cuid())
  tenantId         String
  createdByUserId  String?
  name             String
  slug             String
  description      String?
  templateKey      StorefrontTemplateKey @default(STARTER)
  status           StorefrontPageStatus @default(DRAFT)
  isTemporary      Boolean              @default(false)
  editorSchemaVersion Int               @default(1)
  builderDocument  Json?
  builderLastSavedAt DateTime?
  expiresAt        DateTime?
  graceEndsAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domainConnections DomainConnection[]
  versions         StorefrontPageVersion[]
  customPageRequests CustomPageRequest[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

model StorefrontPageVersion {
  id               String                   @id @default(cuid())
  storefrontPageId String
  createdByUserId  String?
  versionNumber    Int
  kind             StorefrontPageVersionKind @default(AUTOSAVE)
  changeSummary    String?
  snapshot         Json
  createdAt        DateTime                 @default(now())
  storefrontPage   StorefrontPage           @relation(fields: [storefrontPageId], references: [id], onDelete: Cascade)

  @@unique([storefrontPageId, versionNumber])
  @@index([storefrontPageId, createdAt])
}

model DomainConnection {
  id             String                 @id @default(cuid())
  tenantId       String
  storefrontPageId String?
  hostname       String
  status         DomainConnectionStatus @default(NOT_CONFIGURED)
  requiresPaidPlan Boolean              @default(true)
  verifiedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storefrontPage StorefrontPage?        @relation(fields: [storefrontPageId], references: [id], onDelete: SetNull)

  @@unique([tenantId, hostname])
}

model CustomPageRequest {
  id                  String                  @id @default(cuid())
  tenantId            String
  storefrontPageId    String?
  requesterUserId     String?
  requestType         CustomPageRequestType   @default(TEMPLATE_CUSTOMIZATION)
  businessObjective   String
  pageScope           String
  businessDescription String?
  desiredColors       String?
  brandStyle          String?
  desiredFeatures     String?
  visualReferences    String?
  observations        String?
  designReferences    String?
  requiredIntegrations String?
  notes               String?
  premiumRequested    Boolean                 @default(true)
  status              CustomPageRequestStatus @default(SUBMITTED)
  quotedPriceLabel    String?
  reviewNotes         String?
  reviewedAt          DateTime?
  reviewedByUserId    String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storefrontPage      StorefrontPage?         @relation(fields: [storefrontPageId], references: [id], onDelete: SetNull)
  quote               CustomQuote?

  @@index([tenantId, status])
}

model CustomQuote {
  id                   String                  @id @default(cuid())
  tenantId             String
  customPageRequestId  String                  @unique
  createdByUserId      String?
  updatedByUserId      String?
  quoteNumber          String                  @unique
  templateKey          String
  status               CustomQuoteStatus       @default(DRAFT)
  currency             String                  @default("USD")
  baseAmountCents      Int
  extrasAmountCents    Int                     @default(0)
  totalAmountCents     Int
  estimatedDeliveryDays Int
  validUntil           DateTime?
  clientSummary        String
  internalSummary      String?
  observations         String?
  clientResponseMessage String?
  sentAt               DateTime?
  clientRespondedAt    DateTime?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  expiredAt            DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customPageRequest    CustomPageRequest       @relation(fields: [customPageRequestId], references: [id], onDelete: Cascade)
  createdByUser        User?                   @relation("CustomQuoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser        User?                   @relation("CustomQuoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lineItems            CustomQuoteLineItem[]
  revisions            CustomQuoteRevision[]

  @@index([tenantId, status, updatedAt])
}

model CustomQuoteLineItem {
  id               String              @id @default(cuid())
  quoteId          String
  lineType         CustomQuoteLineType
  label            String
  description      String?
  quantity         Int                 @default(1)
  unitAmountCents  Int
  totalAmountCents Int
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  quote            CustomQuote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
}

model CustomQuoteRevision {
  id            String                   @id @default(cuid())
  quoteId       String
  changedByUserId String?
  revisionType  CustomQuoteRevisionType
  summary       String
  snapshot      Json
  createdAt     DateTime                 @default(now())
  quote         CustomQuote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  changedByUser User?                    @relation("CustomQuoteRevisionActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([quoteId, createdAt])
}

model IntegrationApiCredential {
  id                String                      @id @default(cuid())
  tenantId          String
  createdByUserId   String?
  name              String
  keyId             String                      @unique
  keyPrefix         String
  tokenHash         String
  scopes            Json
  requestsPerMinute Int                         @default(120)
  lastUsedAt        DateTime?
  rotatedAt         DateTime?
  revokedAt         DateTime?
  expiresAt         DateTime?
  status            IntegrationCredentialStatus @default(ACTIVE)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  tenant            Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usageLogs         IntegrationUsageLog[]

  @@index([tenantId, status])
}

model IntegrationUsageLog {
  id                String   @id @default(cuid())
  tenantId          String
  credentialId      String?
  requestId         String
  route             String
  method            String
  scope             String
  statusCode        Int
  latencyMs         Int
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credential        IntegrationApiCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([credentialId, createdAt])
}

model IntegrationWebhookEndpoint {
  id                String                   @id @default(cuid())
  tenantId          String
  createdByUserId   String?
  name              String
  url               String
  secretHash        String
  eventTypes        Json
  status            IntegrationWebhookStatus @default(ACTIVE)
  lastTriggeredAt   DateTime?
  lastStatusCode    Int?
  lastFailureAt     DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Category {
  id          String     @id @default(cuid())
  tenantId    String
  parentId    String?
  name        String
  slug        String
  description String?
  data        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    ProductCategory[]

  @@unique([tenantId, slug])
  @@index([tenantId, name])
}

model Product {
  id               String            @id @default(cuid())
  tenantId         String
  sku              String
  name             String
  slug             String
  description      String?
  shortDescription String?
  brand            String?
  status           ProductStatus     @default(ACTIVE)
  currency         String            @default("ARS")
  priceRetail      Decimal           @db.Decimal(10, 2)
  priceWholesale   Decimal?          @db.Decimal(10, 2)
  stock            Int               @default(0)
  images           Json?
  attributes       Json?
  isVisibleWeb     Boolean           @default(true)
  isActiveSource   Boolean           @default(true)
  sourceExternalId String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories       ProductCategory[]
  collections      ProductCollectionItem[]
  reviews          ProductReview[]
  priceOverrides   ProductPriceOverride[]
  orderItems       OrderItem[]
  syncRecords      ProductSyncRecord[]

  @@unique([tenantId, sku])
  @@unique([tenantId, slug])
  @@index([tenantId, status, isVisibleWeb])
}

model ProductCategory {
  productId  String
  categoryId String
  assignedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductCollection {
  id          String                  @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  status      CollectionStatus        @default(ACTIVE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       ProductCollectionItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

model ProductCollectionItem {
  collectionId String
  productId    String
  sortOrder    Int      @default(0)
  assignedAt   DateTime @default(now())
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([productId])
}

model ProductReview {
  id        String       @id @default(cuid())
  tenantId  String
  productId String
  userId    String?
  rating    Int
  comment   String?
  status    ReviewStatus @default(PUBLISHED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, productId, status])
}

model PriceList {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  type        PriceListType
  rulesJson   Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments UserPriceList[]

  @@unique([tenantId, name])
  @@index([tenantId, type])
}

model UserPriceList {
  tenantId    String
  userId      String
  priceListId String
  assignedAt  DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@index([priceListId])
}

model ProductPriceOverride {
  id             String   @id @default(cuid())
  tenantId       String
  productId      String
  hidden         Boolean  @default(false)
  featured       Boolean  @default(false)
  priceRetail    Decimal? @db.Decimal(10, 2)
  priceWholesale Decimal? @db.Decimal(10, 2)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId])
  @@index([tenantId, hidden, featured])
}

model TenantOffer {
  id                String      @id @default(cuid())
  tenantId          String
  name              String
  label             String?
  percent           Decimal     @db.Decimal(5, 2)
  status            OfferStatus @default(ACTIVE)
  targetUserIds     Json?
  targetCategoryIds Json?
  targetProductIds  Json?
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, startsAt, endsAt])
}

model ShippingBranch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  hours     String?
  phone     String?
  pickupFee Decimal  @default(0) @db.Decimal(10, 2)
  latitude  Decimal? @db.Decimal(10, 6)
  longitude Decimal? @db.Decimal(10, 6)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  zones     ShippingZone[]

  @@index([tenantId, enabled])
}

model ShippingZone {
  id                  String              @id @default(cuid())
  tenantId            String
  branchId            String?
  name                String
  description         String?
  type                ShippingZoneType    @default(FLAT)
  distancePricingMode DistancePricingMode @default(FIXED)
  price               Decimal             @default(0) @db.Decimal(10, 2)
  pricePerKm          Decimal             @default(0) @db.Decimal(10, 2)
  polygon             Json?
  coverageMode        String              @default("manual")
  centroid            Json?
  minDistanceKm       Decimal             @default(0) @db.Decimal(10, 2)
  maxDistanceKm       Decimal?            @db.Decimal(10, 2)
  enabled             Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              ShippingBranch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, enabled, type])
}

model Order {
  id             String         @id @default(cuid())
  tenantId       String
  placedByUserId String?
  orderNumber    String         @unique
  status         OrderStatus    @default(PENDING)
  checkoutMethod CheckoutMethod @default(MANUAL)
  orderChannel   OrderChannel   @default(WEB)
  currency       String         @default("ARS")
  subtotalAmount Decimal        @db.Decimal(10, 2)
  shippingAmount Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal        @db.Decimal(10, 2)
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  billingInfo    Json?
  shippingInfo   Json?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  placedByUser   User?          @relation("OrderPlacedBy", fields: [placedByUserId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]

  @@index([tenantId, status, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  sku         String
  name        String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  currency    String
  snapshot    Json?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
}

model Payment {
  id         String        @id @default(cuid())
  tenantId   String
  orderId    String?
  provider   String
  status     PaymentStatus @default(PENDING)
  amount     Decimal       @db.Decimal(10, 2)
  currency   String        @default("ARS")
  reference  String?
  externalId String?
  metadata   Json?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order      Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([orderId, createdAt])
}

model ErpConnection {
  id           String              @id @default(cuid())
  tenantId     String
  name         String
  sourceSystem String
  status       ErpConnectionStatus @default(ACTIVE)
  config       Json?
  lastSyncedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  syncJobs     SyncJob[]
  syncRecords  ProductSyncRecord[]

  @@index([tenantId, status])
}

model SyncJob {
  id              String         @id @default(cuid())
  tenantId        String
  erpConnectionId String?
  sourceSystem    String
  operation       String         @default("upsert")
  status          SyncJobStatus  @default(QUEUED)
  startedAt       DateTime?
  completedAt     DateTime?
  summary         String?
  rawPayload      Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  erpConnection   ErpConnection? @relation(fields: [erpConnectionId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
}

model ProductSyncRecord {
  id              String         @id @default(cuid())
  tenantId        String
  productId       String
  erpConnectionId String?
  externalId      String
  sourceSystem    String
  lastSyncAt      DateTime?
  rawPayload      Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  erpConnection   ErpConnection? @relation(fields: [erpConnectionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalId, sourceSystem])
  @@index([tenantId, productId])
}

model TenantAiWorkspace {
  id                      String                 @id @default(cuid())
  tenantId                String                 @unique
  plan                    AiWorkspacePlan        @default(START)
  assistantDisplayName    String                 @default("Asistente Vase")
  systemPrompt            String?
  modelSlug               String?
  temperature             Decimal?               @db.Decimal(3, 2)
  tone                    AiAssistantTone        @default(PROFESSIONAL)
  trainingStatus          AiTrainingJobStatus    @default(DRAFT)
  timezone                String                 @default("America/Argentina/Buenos_Aires")
  businessHours           Json?
  businessContext         Json?
  bookingEnabled          Boolean                @default(false)
  bookingConfiguration    Json?
  humanEscalationEnabled  Boolean                @default(false)
  escalationDestination   AiEscalationDestination @default(EMAIL)
  escalationContact       String?
  scrapingEnabled         Boolean                @default(true)
  monthlyConversationLimit Int                   @default(300)
  monthlyKnowledgeItemLimit Int                  @default(25)
  maxChannels             Int                    @default(1)
  maxFiles                Int                    @default(8)
  maxUrls                 Int                    @default(5)
  setupCompletedAt        DateTime?
  lastTrainedAt           DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeItems          AiKnowledgeItem[]
  trainingJobs            AiTrainingJob[]
  channels                AiChannelConnection[]
  conversations           AiConversation[]
  supportTickets          SupportTicket[]
}

model AiKnowledgeItem {
  id               String                @id @default(cuid())
  tenantId         String
  workspaceId      String
  createdByUserId  String?
  type             AiKnowledgeItemType
  status           AiKnowledgeItemStatus @default(QUEUED)
  title            String
  fileName         String?
  mimeType         String?
  fileSizeBytes    Int?
  storageKey       String?
  sourceUrl        String?
  faqQuestion      String?
  faqAnswer        String?
  allowedPaths     Json?
  contentSnippet   String?
  processingNotes  String?
  failureReason    String?
  lastProcessedAt  DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        TenantAiWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, status])
}

model AiTrainingJob {
  id               String              @id @default(cuid())
  tenantId         String
  workspaceId      String
  startedByUserId  String?
  status           AiTrainingJobStatus @default(QUEUED)
  sourceCount      Int                 @default(0)
  summary          String?
  failureReason    String?
  queuedAt         DateTime            @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        TenantAiWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
}

model AiChannelConnection {
  id               String          @id @default(cuid())
  tenantId         String
  workspaceId      String
  configuredByUserId String?
  channelType      AiChannelType
  status           AiChannelStatus @default(PENDING)
  accountLabel     String
  externalHandle   String?
  providerAccountId String?
  webhookUrl       String?
  config           Json?
  notes            String?
  connectedAt      DateTime?
  lastSyncedAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        TenantAiWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelType, accountLabel])
  @@index([tenantId, status])
}

model AiConversation {
  id                    String               @id @default(cuid())
  tenantId              String
  workspaceId           String
  channelType           AiChannelType
  status                AiConversationStatus @default(OPEN)
  customerName          String?
  customerContact       String?
  externalThreadKey     String?
  summary               String?
  metadata              Json?
  messageCount          Int                  @default(0)
  escalatedToHuman      Boolean              @default(false)
  escalationRequestedAt DateTime?
  startedAt             DateTime             @default(now())
  lastMessageAt         DateTime             @default(now())
  lastInboundAt         DateTime?
  lastOutboundAt        DateTime?
  closedAt              DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace             TenantAiWorkspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supportTicket         SupportTicket?

  @@index([tenantId, status, lastMessageAt])
  @@unique([tenantId, channelType, externalThreadKey])
}

model SupportTicket {
  id                    String                 @id @default(cuid())
  tenantId              String
  workspaceId           String?
  conversationId        String?                @unique
  createdByUserId       String?
  assignedToUserId      String?
  assignmentMode        SupportAssignmentMode  @default(MANUAL)
  source                SupportTicketSource    @default(MANUAL)
  priority              SupportTicketPriority  @default(NORMAL)
  status                SupportTicketStatus    @default(QUEUED)
  subject               String
  customerName          String?
  customerContact       String?
  aiSummary             String?
  resolutionSummary     String?
  queueEnteredAt        DateTime               @default(now())
  waitingSince          DateTime               @default(now())
  estimatedWaitMinutes  Int                    @default(20)
  firstAssignedAt       DateTime?
  firstResponseAt       DateTime?
  resolvedAt            DateTime?
  returnedToAiAt        DateTime?
  closedAt              DateTime?
  lastCustomerMessageAt DateTime?
  lastAgentMessageAt    DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace             TenantAiWorkspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  conversation          AiConversation?        @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdByUser         User?                  @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedToUser        User?                  @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  events                SupportTicketEvent[]
  notes                 SupportTicketNote[]
  notifications         SupportNotification[]

  @@index([tenantId, status, priority, queueEnteredAt])
  @@index([assignedToUserId, status, updatedAt])
}

model SupportTicketEvent {
  id            String                  @id @default(cuid())
  ticketId      String
  actorUserId   String?
  eventType     SupportTicketEventType
  message       String
  metadata      Json?
  createdAt     DateTime                @default(now())
  ticket        SupportTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser     User?                   @relation("SupportTicketActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model SupportTicketNote {
  id            String         @id @default(cuid())
  ticketId      String
  authorUserId  String
  body          String
  createdAt     DateTime       @default(now())
  ticket        SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser    User           @relation("SupportNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model SupportReplyTemplate {
  id            String    @id @default(cuid())
  tenantId      String?
  createdByUserId String?
  name          String
  category      String?
  body          String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?     @relation("SupportTemplateAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, isActive, name])
}

model SupportKnowledgeItem {
  id              String    @id @default(cuid())
  tenantId        String?
  question        String
  answer          String
  category        String?
  tags            Json?
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser   User      @relation("SupportKnowledgeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  aiResponseLogs  SupportAiResponseKnowledgeItem[]

  @@index([tenantId, isActive, updatedAt])
  @@index([category, isActive, updatedAt])
}

model SupportAiResponseLog {
  id                String                           @id @default(cuid())
  tenantId          String?
  requestedByUserId String?
  message           String
  reply             String
  helpful           Boolean?
  feedbackNote      String?
  feedbackAt        DateTime?
  knowledgeCount    Int                              @default(0)
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt
  tenant            Tenant?                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUser   User?                            @relation("SupportAiResponseRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  knowledgeItems    SupportAiResponseKnowledgeItem[]

  @@index([tenantId, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([helpful, createdAt])
}

model SupportAiResponseKnowledgeItem {
  id                String               @id @default(cuid())
  responseLogId     String
  knowledgeItemId   String
  relevanceScore    Int
  position          Int
  categorySnapshot  String?
  createdAt         DateTime             @default(now())
  responseLog       SupportAiResponseLog @relation(fields: [responseLogId], references: [id], onDelete: Cascade)
  knowledgeItem     SupportKnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@unique([responseLogId, knowledgeItemId])
  @@index([knowledgeItemId, createdAt])
  @@index([responseLogId, position])
}

model SupportNotification {
  id              String                   @id @default(cuid())
  ticketId        String
  tenantId        String
  recipientUserId String?
  type            SupportNotificationType
  title           String
  message         String
  readAt          DateTime?
  createdAt       DateTime                 @default(now())
  ticket          SupportTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipientUser   User?                    @relation("SupportNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([recipientUserId, readAt, createdAt])
}

model PlatformUpdate {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  href        String?
  tone        String   @default("info")
  category    String   @default("platform")
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  readBy      PlatformUpdateRead[]
}

model PlatformUpdateRead {
  id               String         @id @default(cuid())
  updateId        String
  userId          String
  readAt          DateTime       @default(now())
  update          PlatformUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([updateId, userId])
}
